{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mutsuki.agent-tool.v1",
  "type": "object",
  "required": ["name", "target_protocol_id", "description"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "target_protocol_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "input_schema": true,
    "output_schema": true,
    "side_effect": {
      "enum": ["none", "workspace_read", "workspace_write", "external_read", "external_write"]
    },
    "requires_approval": { "type": "boolean" },
    "permissions": { "type": "array", "items": { "type": "string" } }
  }
}
